{
  "name": "btg-report-functions",
  "description": "Firebase Functions para Reporte Trimestral BTG Pactual",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "lint": "eslint --ext .ts .",
    "deploy": "firebase deploy --only functions"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "@sparticuz/chromium": "^133.0.0",
    "puppeteer-core": "^24.0.0",
    "pdfkit": "^0.18.0",
    "express": "^4.18.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "@types/pdfkit": "^0.13.0",
    "firebase-functions-test": "^3.1.0"
  },
  "private": true
}
